# Pulse is a personal project — pull from the public npm registry, not
# the Amplify CodeArtifact proxy that's set globally in ~/.npmrc.
# A project-local .npmrc takes precedence over the user one.
registry=https://registry.npmjs.org/
@tauri-apps:registry=https://registry.npmjs.org/
@types:registry=https://registry.npmjs.org/
@vitejs:registry=https://registry.npmjs.org/

# Belt-and-suspenders: blank out the inherited auth tokens so pnpm
# doesn't send a stale Bearer header to public npm.
//registry.npmjs.org/:_authToken=
//amplify-023225265359.d.codeartifact.us-west-2.amazonaws.com/npm/amplify-npm/:_authToken=
//aws-codeartifact-proxy-npm-devops.devops.amplify.com/:_authToken=

auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false
