{
  "name": "pulse",
  "private": true,
  "version": "0.1.0",
  "description": "AI usage tracker for developer teams.",
  "type": "module",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.10",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --filter @pulse/desktop tauri:dev",
    "build": "pnpm --filter @pulse/desktop tauri:build",
    "tauri:dev": "pnpm --filter @pulse/desktop tauri:dev",
    "tauri:build": "pnpm --filter @pulse/desktop tauri:build",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css}\"",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  }
}
